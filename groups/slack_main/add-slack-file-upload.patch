### STEP 2 — src/channels/slack.ts
### Add sendFile method using Slack's v2 upload API

After the `sendMessage` method (around line 212), add:

```typescript
async sendFile(jid: string, filePath: string, caption?: string): Promise<void> {
  const channelId = jid.replace(/^slack:/, '');
  const fs = await import('fs');
  const path = await import('path');

  if (!fs.existsSync(filePath)) {
    logger.error({ filePath }, 'sendFile: file does not exist');
    return;
  }

  const filename = path.basename(filePath);
  const fileBuffer = fs.readFileSync(filePath);
  const fileSize = fileBuffer.length;

  try {
    // Step 1: Get upload URL
    const urlRes = await this.app.client.files.getUploadURLExternal({
      filename,
      length: fileSize,
      token: this.botToken,
    });

    if (!urlRes.upload_url || !urlRes.file_id) {
      logger.error({ urlRes }, 'sendFile: failed to get upload URL');
      return;
    }

    // Step 2: Upload the file content to the upload URL
    await fetch(urlRes.upload_url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/octet-stream' },
      body: fileBuffer,
    });

    // Step 3: Complete the upload and post to channel
    await this.app.client.files.completeUploadExternal({
      files: [{ id: urlRes.file_id, title: caption ?? filename }],
      channel_id: channelId,
      initial_comment: caption ?? '',
      token: this.botToken,
    });

    logger.info({ filePath, channelId }, 'File uploaded to Slack successfully');
  } catch (err) {
    logger.error({ filePath, channelId, err }, 'sendFile: upload failed');
  }
}
```

